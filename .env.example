# QA Dashboard Environment Variables
# Copy this file to .env and fill in your values

# Database (default values work with docker-compose)
DATABASE_URL=postgresql://postgres:postgres@db:5432/qa_dashboard

# Redis (default values work with docker-compose)
REDIS_URL=redis://redis:6379

# Slack notifications (optional)
# Get webhook URL from: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# For CI/CD (GitHub Actions)
# These are set automatically by GitHub Actions
# GITHUB_SHA=
# GITHUB_REF_NAME=
